<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" 
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0" 
                  id="Definitions_Agent" 
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler" 
                  exporterVersion="5.44.0" 
                  modeler:executionPlatform="Camunda Cloud" 
                  modeler:executionPlatformVersion="8.9.0">
  
  <bpmn:process id="agent-with-tools" name="AI Agent with CLI Tools" isExecutable="true">
    
    <!-- 
    Process Variables:
    - userPrompt: The user's request/question
    - openaiApiKey: API key for LLM calls
    - toolsToActivate: List of tool IDs to activate in ad-hoc subprocess
    - agentDecision: The agent's current decision (use_tool or final_answer)
    - toolResults: Array of results from tool executions
    - finalResponse: The agent's final answer
    - iterationCount: Current iteration counter
    - maxIterations: Maximum iterations (default 10)
    - isComplete: Boolean flag for completion
    -->
    
    <bpmn:startEvent id="StartEvent" name="User Request">
      <bpmn:outgoing>Flow_Start_To_Init</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- Initialize agent state -->
    <bpmn:scriptTask id="Task_InitAgent" name="Initialize Agent">
      <bpmn:extensionElements>
        <zeebe:script expression="={
          toolResults: [],
          iterationCount: 0,
          maxIterations: if maxIterations = null then 10 else maxIterations,
          isComplete: false,
          toolsToActivate: []
        }" resultVariable="agentInit" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Init</bpmn:incoming>
      <bpmn:outgoing>Flow_Init_To_Loop</bpmn:outgoing>
    </bpmn:scriptTask>
    
    <!-- Agent reasoning loop - repeats until complete or max iterations -->
    <bpmn:subProcess id="AgentReasoningLoop" name="Agent Reasoning Loop">
      <bpmn:incoming>Flow_Init_To_Loop</bpmn:incoming>
      <bpmn:incoming>Flow_LoopBack</bpmn:incoming>
      <bpmn:outgoing>Flow_Loop_To_Gateway</bpmn:outgoing>
      
      <bpmn:startEvent id="Loop_Start">
        <bpmn:outgoing>Flow_LoopStart_To_Think</bpmn:outgoing>
      </bpmn:startEvent>
      
      <!-- Agent thinks using LLM -->
      <bpmn:serviceTask id="Task_AgentThink" name="Agent Thinks (LLM)">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" />
          <zeebe:ioMapping>
            <zeebe:input source="POST" target="method" />
            <zeebe:input source="https://api.openai.com/v1/chat/completions" target="url" />
            <zeebe:input source="={
              &quot;Content-Type&quot;: &quot;application/json&quot;,
              &quot;Authorization&quot;: &quot;Bearer &quot; + openaiApiKey
            }" target="headers" />
            <zeebe:input source="={
              &quot;model&quot;: &quot;gpt-4&quot;,
              &quot;messages&quot;: flatten([
                [{
                  &quot;role&quot;: &quot;system&quot;,
                  &quot;content&quot;: &quot;You are an AI agent with CLI tools. Available tools:\n- jq: Parse/transform JSON\n- yq: Parse/transform YAML\n- curl: HTTP requests (GET only)\n- kubectl: Query Kubernetes (read-only)\n- python: Run Python scripts\n\nRespond with JSON:\nTo use a tool: {\\&quot;action\\&quot;:\\&quot;use_tool\\&quot;,\\&quot;tool\\&quot;:\\&quot;tool_name\\&quot;,\\&quot;arguments\\&quot;:\\&quot;args\\&quot;,\\&quot;reasoning\\&quot;:\\&quot;why\\&quot;}\nTo answer: {\\&quot;action\\&quot;:\\&quot;final_answer\\&quot;,\\&quot;answer\\&quot;:\\&quot;your answer\\&quot;}&quot;
                },
                {
                  &quot;role&quot;: &quot;user&quot;,
                  &quot;content&quot;: userPrompt
                }],
                for result in toolResults return {
                  &quot;role&quot;: &quot;assistant&quot;,
                  &quot;content&quot;: &quot;Tool &quot; + result.tool + &quot; returned: &quot; + result.output
                }
              ]),
              &quot;temperature&quot;: 0.3,
              &quot;response_format&quot;: {&quot;type&quot;: &quot;json_object&quot;}
            }" target="body" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="resultVariable" value="llmResponse" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_LoopStart_To_Think</bpmn:incoming>
        <bpmn:outgoing>Flow_Think_To_Parse</bpmn:outgoing>
      </bpmn:serviceTask>
      
      <!-- Parse agent decision -->
      <bpmn:scriptTask id="Task_ParseDecision" name="Parse Decision">
        <bpmn:extensionElements>
          <zeebe:script expression="={
            agentDecision: json(llmResponse.body.choices[1].message.content),
            iterationCount: iterationCount + 1,
            toolsToActivate: if json(llmResponse.body.choices[1].message.content).action = &quot;use_tool&quot; 
              then [&quot;Tool_&quot; + json(llmResponse.body.choices[1].message.content).tool] 
              else []
          }" resultVariable="parseResult" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_Think_To_Parse</bpmn:incoming>
        <bpmn:outgoing>Flow_Parse_To_ToolGateway</bpmn:outgoing>
      </bpmn:scriptTask>
      
      <!-- Gateway: Execute tool or skip? -->
      <bpmn:exclusiveGateway id="Gateway_UseTool" name="Use Tool?">
        <bpmn:incoming>Flow_Parse_To_ToolGateway</bpmn:incoming>
        <bpmn:outgoing>Flow_Gateway_To_AdHoc</bpmn:outgoing>
        <bpmn:outgoing>Flow_Gateway_To_LoopEnd</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      
      <!-- Ad-hoc subprocess for tool execution (Camunda 8.7+ style) -->
      <bpmn:adHocSubProcess id="ToolBox" name="Agent Toolbox" cancelRemainingInstances="true">
        <bpmn:extensionElements>
          <zeebe:adHoc activeElementsCollection="=toolsToActivate" />
          <zeebe:ioMapping>
            <zeebe:input source="=agentDecision" target="toolCall" />
            <zeebe:output source="=toolOutput" target="lastToolOutput" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_Gateway_To_AdHoc</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_To_Collect</bpmn:outgoing>
        
        <!-- No start/end events - elements are activated by activeElementsCollection -->
        
        <!-- Tool: jq - JSON Processing -->
        <bpmn:serviceTask id="Tool_jq" name="jq: JSON Processor" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
          <bpmn:documentation>Parse and transform JSON data using jq expressions</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
            <zeebe:ioMapping>
              <zeebe:input source="execute" target="action" />
              <zeebe:input source="default" target="tenantId" />
              <zeebe:input source="command" target="executionMode" />
              <zeebe:input source="jq" target="selectedTool" />
              <zeebe:input source="=toolCall.arguments" target="commandArguments" />
              <zeebe:input source="=&quot;jq &quot; + toolCall.arguments" target="command" />
              <zeebe:input source="=[&quot;jq&quot;]" target="allowedTools" />
              <zeebe:input source="=if toolCall.input_data != null then toolCall.input_data else &quot;&quot;" target="inputData" />
              <zeebe:input source="NONE" target="networkAccess" />
              <zeebe:input source="30" target="timeoutSeconds" />
              <zeebe:input source="256" target="memoryLimitMb" />
            </zeebe:ioMapping>
            <zeebe:taskHeaders>
              <zeebe:header key="resultVariable" value="toolOutput" />
            </zeebe:taskHeaders>
            <zeebe:properties>
              <zeebe:property name="tool_type" value="data_processing" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:serviceTask>
        
        <!-- Tool: yq - YAML Processing -->
        <bpmn:serviceTask id="Tool_yq" name="yq: YAML Processor" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
          <bpmn:documentation>Parse and transform YAML data using yq expressions</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
            <zeebe:ioMapping>
              <zeebe:input source="execute" target="action" />
              <zeebe:input source="default" target="tenantId" />
              <zeebe:input source="command" target="executionMode" />
              <zeebe:input source="yq" target="selectedTool" />
              <zeebe:input source="=toolCall.arguments" target="commandArguments" />
              <zeebe:input source="=&quot;yq &quot; + toolCall.arguments" target="command" />
              <zeebe:input source="=[&quot;yq&quot;]" target="allowedTools" />
              <zeebe:input source="=if toolCall.input_data != null then toolCall.input_data else &quot;&quot;" target="inputData" />
              <zeebe:input source="NONE" target="networkAccess" />
              <zeebe:input source="30" target="timeoutSeconds" />
              <zeebe:input source="256" target="memoryLimitMb" />
            </zeebe:ioMapping>
            <zeebe:taskHeaders>
              <zeebe:header key="resultVariable" value="toolOutput" />
            </zeebe:taskHeaders>
            <zeebe:properties>
              <zeebe:property name="tool_type" value="data_processing" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:serviceTask>
        
        <!-- Tool: curl - HTTP Requests -->
        <bpmn:serviceTask id="Tool_curl" name="curl: HTTP Client" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
          <bpmn:documentation>Make HTTP GET requests to external APIs</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
            <zeebe:ioMapping>
              <zeebe:input source="execute" target="action" />
              <zeebe:input source="development" target="tenantId" />
              <zeebe:input source="command" target="executionMode" />
              <zeebe:input source="curl" target="selectedTool" />
              <zeebe:input source="=&quot;-s &quot; + toolCall.arguments" target="commandArguments" />
              <zeebe:input source="=&quot;curl -s &quot; + toolCall.arguments" target="command" />
              <zeebe:input source="=[&quot;curl&quot;]" target="allowedTools" />
              <zeebe:input source="RESTRICTED" target="networkAccess" />
              <zeebe:input source="60" target="timeoutSeconds" />
              <zeebe:input source="256" target="memoryLimitMb" />
            </zeebe:ioMapping>
            <zeebe:taskHeaders>
              <zeebe:header key="resultVariable" value="toolOutput" />
            </zeebe:taskHeaders>
            <zeebe:properties>
              <zeebe:property name="tool_type" value="network" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:serviceTask>
        
        <!-- Tool: kubectl - Kubernetes Queries -->
        <bpmn:serviceTask id="Tool_kubectl" name="kubectl: K8s Query" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
          <bpmn:documentation>Query Kubernetes cluster resources (read-only)</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
            <zeebe:ioMapping>
              <zeebe:input source="execute" target="action" />
              <zeebe:input source="monitoring" target="tenantId" />
              <zeebe:input source="command" target="executionMode" />
              <zeebe:input source="kubectl" target="selectedTool" />
              <zeebe:input source="=toolCall.arguments" target="commandArguments" />
              <zeebe:input source="=&quot;kubectl &quot; + toolCall.arguments" target="command" />
              <zeebe:input source="=[&quot;kubectl&quot;]" target="allowedTools" />
              <zeebe:input source="INTERNAL" target="networkAccess" />
              <zeebe:input source="60" target="timeoutSeconds" />
              <zeebe:input source="256" target="memoryLimitMb" />
            </zeebe:ioMapping>
            <zeebe:taskHeaders>
              <zeebe:header key="resultVariable" value="toolOutput" />
            </zeebe:taskHeaders>
            <zeebe:properties>
              <zeebe:property name="tool_type" value="kubernetes" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:serviceTask>
        
        <!-- Tool: Python - Script Execution -->
        <bpmn:serviceTask id="Tool_python" name="python: Script Runner" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
          <bpmn:documentation>Execute Python scripts for calculations and data processing</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
            <zeebe:ioMapping>
              <zeebe:input source="execute" target="action" />
              <zeebe:input source="default" target="tenantId" />
              <zeebe:input source="script" target="executionMode" />
              <zeebe:input source="safe-python3" target="selectedTool" />
              <zeebe:input source="python" target="scriptLanguage" />
              <zeebe:input source="=toolCall.arguments" target="scriptContent" />
              <zeebe:input source="=[&quot;safe-python3&quot;]" target="allowedTools" />
              <zeebe:input source="=if toolCall.input_data != null then toolCall.input_data else &quot;&quot;" target="inputData" />
              <zeebe:input source="NONE" target="networkAccess" />
              <zeebe:input source="30" target="timeoutSeconds" />
              <zeebe:input source="512" target="memoryLimitMb" />
            </zeebe:ioMapping>
            <zeebe:taskHeaders>
              <zeebe:header key="resultVariable" value="toolOutput" />
            </zeebe:taskHeaders>
            <zeebe:properties>
              <zeebe:property name="tool_type" value="scripting" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:serviceTask>
        
        <!-- Completion: when one tool finishes, the ad-hoc subprocess completes -->
        <bpmn:completionCondition xsi:type="bpmn:tFormalExpression">=true</bpmn:completionCondition>
      </bpmn:adHocSubProcess>
      
      <!-- Collect tool result -->
      <bpmn:scriptTask id="Task_CollectResult" name="Collect Result">
        <bpmn:extensionElements>
          <zeebe:script expression="={
            toolResults: append(toolResults, {
              &quot;tool&quot;: agentDecision.tool,
              &quot;arguments&quot;: agentDecision.arguments,
              &quot;output&quot;: if lastToolOutput.success then lastToolOutput.stdout else &quot;Error: &quot; + lastToolOutput.stderr,
              &quot;success&quot;: lastToolOutput.success
            })
          }" resultVariable="collectResult" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_AdHoc_To_Collect</bpmn:incoming>
        <bpmn:outgoing>Flow_Collect_To_LoopEnd</bpmn:outgoing>
      </bpmn:scriptTask>
      
      <bpmn:endEvent id="Loop_End">
        <bpmn:incoming>Flow_Gateway_To_LoopEnd</bpmn:incoming>
        <bpmn:incoming>Flow_Collect_To_LoopEnd</bpmn:incoming>
      </bpmn:endEvent>
      
      <!-- Sequence flows inside subprocess -->
      <bpmn:sequenceFlow id="Flow_LoopStart_To_Think" sourceRef="Loop_Start" targetRef="Task_AgentThink" />
      <bpmn:sequenceFlow id="Flow_Think_To_Parse" sourceRef="Task_AgentThink" targetRef="Task_ParseDecision" />
      <bpmn:sequenceFlow id="Flow_Parse_To_ToolGateway" sourceRef="Task_ParseDecision" targetRef="Gateway_UseTool" />
      <bpmn:sequenceFlow id="Flow_Gateway_To_AdHoc" name="use_tool" sourceRef="Gateway_UseTool" targetRef="ToolBox">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agentDecision.action = "use_tool"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_Gateway_To_LoopEnd" name="final_answer" sourceRef="Gateway_UseTool" targetRef="Loop_End">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agentDecision.action = "final_answer"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_AdHoc_To_Collect" sourceRef="ToolBox" targetRef="Task_CollectResult" />
      <bpmn:sequenceFlow id="Flow_Collect_To_LoopEnd" sourceRef="Task_CollectResult" targetRef="Loop_End" />
    </bpmn:subProcess>
    
    <!-- Check if we should continue looping or finish -->
    <bpmn:exclusiveGateway id="Gateway_Continue" name="Continue or Done?">
      <bpmn:incoming>Flow_Loop_To_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_LoopBack</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_Format</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_MaxIter</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <!-- Loop back for more tool calls -->
    <bpmn:sequenceFlow id="Flow_LoopBack" name="Continue (tool used)" sourceRef="Gateway_Continue" targetRef="AgentReasoningLoop">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agentDecision.action = "use_tool" and iterationCount &lt; maxIterations</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <!-- Store final answer -->
    <bpmn:scriptTask id="Task_StoreFinal" name="Store Final Answer">
      <bpmn:extensionElements>
        <zeebe:script expression="={
          finalResponse: agentDecision.answer,
          isComplete: true
        }" resultVariable="finalResult" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_To_Format</bpmn:incoming>
      <bpmn:outgoing>Flow_Final_To_Format</bpmn:outgoing>
    </bpmn:scriptTask>
    
    <!-- Max iterations reached -->
    <bpmn:scriptTask id="Task_MaxIterations" name="Max Iterations Reached">
      <bpmn:extensionElements>
        <zeebe:script expression="={
          finalResponse: &quot;Maximum iterations reached. Based on available information: &quot; + 
            (if count(toolResults) > 0 then toolResults[count(toolResults)].output else &quot;No tool results available.&quot;),
          isComplete: true
        }" resultVariable="maxIterResult" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_To_MaxIter</bpmn:incoming>
      <bpmn:outgoing>Flow_MaxIter_To_Format</bpmn:outgoing>
    </bpmn:scriptTask>
    
    <!-- Format final response -->
    <bpmn:serviceTask id="Task_FormatResponse" name="Format Response" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
        <zeebe:ioMapping>
          <zeebe:input source="execute" target="action" />
          <zeebe:input source="default" target="tenantId" />
          <zeebe:input source="script" target="executionMode" />
          <zeebe:input source="safe-python3" target="selectedTool" />
          <zeebe:input source="python" target="scriptLanguage" />
          <zeebe:input source="import json
from datetime import datetime

data = json.loads(input())

response = {
    'answer': data.get('finalResponse', 'No response'),
    'tools_used': [r['tool'] for r in data.get('toolResults', [])],
    'iterations': data.get('iterationCount', 0),
    'timestamp': datetime.now().isoformat()
}

print(json.dumps(response, indent=2))" target="scriptContent" />
          <zeebe:input source="=[&quot;safe-python3&quot;]" target="allowedTools" />
          <zeebe:input source="={
            &quot;finalResponse&quot;: finalResponse,
            &quot;toolResults&quot;: toolResults,
            &quot;iterationCount&quot;: iterationCount
          }" target="inputData" />
          <zeebe:input source="NONE" target="networkAccess" />
          <zeebe:input source="30" target="timeoutSeconds" />
          <zeebe:input source="256" target="memoryLimitMb" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="agentResponse" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Final_To_Format</bpmn:incoming>
      <bpmn:incoming>Flow_MaxIter_To_Format</bpmn:incoming>
      <bpmn:outgoing>Flow_Format_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:endEvent id="EndEvent" name="Response Ready">
      <bpmn:incoming>Flow_Format_To_End</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- Main process sequence flows -->
    <bpmn:sequenceFlow id="Flow_Start_To_Init" sourceRef="StartEvent" targetRef="Task_InitAgent" />
    <bpmn:sequenceFlow id="Flow_Init_To_Loop" sourceRef="Task_InitAgent" targetRef="AgentReasoningLoop" />
    <bpmn:sequenceFlow id="Flow_Loop_To_Gateway" sourceRef="AgentReasoningLoop" targetRef="Gateway_Continue" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_Format" name="final_answer" sourceRef="Gateway_Continue" targetRef="Task_StoreFinal">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=agentDecision.action = "final_answer"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gateway_To_MaxIter" name="max iterations" sourceRef="Gateway_Continue" targetRef="Task_MaxIterations">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=iterationCount >= maxIterations and agentDecision.action = "use_tool"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Final_To_Format" sourceRef="Task_StoreFinal" targetRef="Task_FormatResponse" />
    <bpmn:sequenceFlow id="Flow_MaxIter_To_Format" sourceRef="Task_MaxIterations" targetRef="Task_FormatResponse" />
    <bpmn:sequenceFlow id="Flow_Format_To_End" sourceRef="Task_FormatResponse" targetRef="EndEvent" />
    
  </bpmn:process>
  
  <!-- Diagram Information -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="agent-with-tools">
      
      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent">
        <dc:Bounds x="152" y="342" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="135" y="385" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Init Agent -->
      <bpmndi:BPMNShape id="Task_InitAgent_di" bpmnElement="Task_InitAgent">
        <dc:Bounds x="240" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <!-- Agent Reasoning Loop Subprocess -->
      <bpmndi:BPMNShape id="AgentReasoningLoop_di" bpmnElement="AgentReasoningLoop" isExpanded="true">
        <dc:Bounds x="390" y="80" width="820" height="520" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <!-- Loop Start -->
      <bpmndi:BPMNShape id="Loop_Start_di" bpmnElement="Loop_Start">
        <dc:Bounds x="420" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      
      <!-- Agent Think -->
      <bpmndi:BPMNShape id="Task_AgentThink_di" bpmnElement="Task_AgentThink">
        <dc:Bounds x="490" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <!-- Parse Decision -->
      <bpmndi:BPMNShape id="Task_ParseDecision_di" bpmnElement="Task_ParseDecision">
        <dc:Bounds x="620" y="320" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <!-- Use Tool Gateway -->
      <bpmndi:BPMNShape id="Gateway_UseTool_di" bpmnElement="Gateway_UseTool" isMarkerVisible="true">
        <dc:Bounds x="755" y="335" width="50" height="50" />
