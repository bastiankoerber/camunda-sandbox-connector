<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" 
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0" 
                  id="Definitions_1" 
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler" 
                  exporterVersion="5.44.0" 
                  modeler:executionPlatform="Camunda Cloud" 
                  modeler:executionPlatformVersion="8.9.0">
  
  <bpmn:process id="cli-demo" name="CLI Sandbox Demo" isExecutable="true">
    
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- Task 1: Parse JSON with jq -->
    <bpmn:serviceTask id="Task_ParseJson" name="Parse JSON with jq" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
        <zeebe:ioMapping>
          <zeebe:input source="execute" target="action" />
          <zeebe:input source="default" target="tenantId" />
          <zeebe:input source="command" target="executionMode" />
          <zeebe:input source="jq" target="selectedTool" />
          <zeebe:input source=".users | length" target="commandArguments" />
          <zeebe:input source="=selectedTool + &quot; &quot; + commandArguments" target="command" />
          <zeebe:input source="=[selectedTool]" target="allowedTools" />
          <zeebe:input source="{&quot;users&quot;: [{&quot;name&quot;: &quot;Alice&quot;}, {&quot;name&quot;: &quot;Bob&quot;}, {&quot;name&quot;: &quot;Charlie&quot;}]}" target="inputData" />
          <zeebe:input source="NONE" target="networkAccess" />
          <zeebe:input source="30" target="timeoutSeconds" />
          <zeebe:input source="256" target="memoryLimitMb" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="jqResult" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Task 2: Filter users with jq -->
    <bpmn:serviceTask id="Task_FilterUsers" name="Filter Active Users" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
        <zeebe:ioMapping>
          <zeebe:input source="execute" target="action" />
          <zeebe:input source="default" target="tenantId" />
          <zeebe:input source="command" target="executionMode" />
          <zeebe:input source="jq" target="selectedTool" />
          <zeebe:input source="-r &apos;.users[] | select(.active == true) | .name&apos;" target="commandArguments" />
          <zeebe:input source="=selectedTool + &quot; &quot; + commandArguments" target="command" />
          <zeebe:input source="=[selectedTool]" target="allowedTools" />
          <zeebe:input source="{&quot;users&quot;: [{&quot;name&quot;: &quot;Alice&quot;, &quot;active&quot;: true}, {&quot;name&quot;: &quot;Bob&quot;, &quot;active&quot;: false}, {&quot;name&quot;: &quot;Charlie&quot;, &quot;active&quot;: true}]}" target="inputData" />
          <zeebe:input source="NONE" target="networkAccess" />
          <zeebe:input source="30" target="timeoutSeconds" />
          <zeebe:input source="256" target="memoryLimitMb" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="activeUsers" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Task 3: Transform with yq (YAML) -->
    <bpmn:serviceTask id="Task_TransformYaml" name="Transform YAML with yq" zeebe:modelerTemplate="io.camunda.connectors.SandboxCLI.v1" zeebe:modelerTemplateVersion="7">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sandbox-cli:1" />
        <zeebe:ioMapping>
          <zeebe:input source="execute" target="action" />
          <zeebe:input source="default" target="tenantId" />
          <zeebe:input source="command" target="executionMode" />
          <zeebe:input source="yq" target="selectedTool" />
          <zeebe:input source="-o=json &apos;.metadata.name&apos;" target="commandArguments" />
          <zeebe:input source="=selectedTool + &quot; &quot; + commandArguments" target="command" />
          <zeebe:input source="=[selectedTool]" target="allowedTools" />
          <zeebe:input source="metadata:
  name: my-deployment
  namespace: default
spec:
  replicas: 3" target="inputData" />
          <zeebe:input source="NONE" target="networkAccess" />
          <zeebe:input source="30" target="timeoutSeconds" />
          <zeebe:input source="256" target="memoryLimitMb" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="yamlResult" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_ParseJson" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ParseJson" targetRef="Task_FilterUsers" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_FilterUsers" targetRef="Task_TransformYaml" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_TransformYaml" targetRef="EndEvent_1" />
    
  </bpmn:process>
  
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="cli-demo">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="158" y="145" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ParseJson_di" bpmnElement="Task_ParseJson">
        <dc:Bounds x="250" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FilterUsers_di" bpmnElement="Task_FilterUsers">
        <dc:Bounds x="410" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TransformYaml_di" bpmnElement="Task_TransformYaml">
        <dc:Bounds x="570" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="732" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="740" y="145" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="120" />
        <di:waypoint x="250" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="350" y="120" />
        <di:waypoint x="410" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="510" y="120" />
        <di:waypoint x="570" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="670" y="120" />
        <di:waypoint x="732" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
  
</bpmn:definitions>
