<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    
    <!-- Define properties -->
    <property name="LOG_PATH" value="${LOG_PATH:-/var/log/sandbox-connector}"/>
    <property name="LOG_FILE" value="${LOG_FILE:-sandbox-connector}"/>
    <property name="LOG_LEVEL" value="${LOG_LEVEL:-INFO}"/>
    <property name="LOG_MAX_SIZE" value="${LOG_MAX_SIZE:-100MB}"/>
    <property name="LOG_MAX_HISTORY" value="${LOG_MAX_HISTORY:-30}"/>
    <property name="LOG_TOTAL_SIZE_CAP" value="${LOG_TOTAL_SIZE_CAP:-3GB}"/>
    
    <!-- Pattern for console output -->
    <property name="CONSOLE_PATTERN" 
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{tenantId:-system}] [%X{executionId:-}] %logger{36} - %msg%n"/>
    
    <!-- Pattern for file output (JSON for log aggregation) -->
    <property name="FILE_PATTERN" 
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{tenantId:-system}] [%X{executionId:-}] %logger{36} - %msg%n"/>
    
    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- JSON Console Appender for Kubernetes -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <includeMdcKeyName>executionId</includeMdcKeyName>
            <includeMdcKeyName>tool</includeMdcKeyName>
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <message>message</message>
                <logger>logger</logger>
                <thread>thread</thread>
                <level>level</level>
                <stackTrace>stacktrace</stackTrace>
            </fieldNames>
            <customFields>{"service":"sandbox-connector","version":"${project.version:-unknown}"}</customFields>
        </encoder>
    </appender>
    
    <!-- Rolling File Appender for application logs -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- Audit Log Appender - separate file for audit events -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE}-audit.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_SIZE}</maxFileSize>
            <maxHistory>90</maxHistory>  <!-- Keep audit logs longer -->
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <includeMdcKeyName>executionId</includeMdcKeyName>
            <includeMdcKeyName>tool</includeMdcKeyName>
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>action</includeMdcKeyName>
            <includeMdcKeyName>outcome</includeMdcKeyName>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            <customFields>{"type":"audit","service":"sandbox-connector"}</customFields>
        </encoder>
    </appender>
    
    <!-- Security Log Appender - separate file for security events -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}-security.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE}-security.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_SIZE}</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <includeMdcKeyName>executionId</includeMdcKeyName>
            <includeMdcKeyName>sourceIp</includeMdcKeyName>
            <includeMdcKeyName>securityEvent</includeMdcKeyName>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            <customFields>{"type":"security","service":"sandbox-connector"}</customFields>
        </encoder>
    </appender>
    
    <!-- Async wrapper for FILE appender -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE"/>
    </appender>
    
    <!-- Async wrapper for AUDIT appender -->
    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>  <!-- Never discard audit logs -->
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="AUDIT_FILE"/>
    </appender>
    
    <!-- Async wrapper for SECURITY appender -->
    <appender name="ASYNC_SECURITY" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>  <!-- Never discard security logs -->
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="SECURITY_FILE"/>
    </appender>
    
    <!-- Logger configurations -->
    
    <!-- Application loggers -->
    <logger name="io.camunda.connector.sandbox" level="${LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    
    <!-- Audit logger - all audit events go here -->
    <logger name="io.camunda.connector.sandbox.audit" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_AUDIT"/>
    </logger>
    
    <!-- Security logger - security events, validation failures, etc. -->
    <logger name="io.camunda.connector.sandbox.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_SECURITY"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    
    <!-- Execution logger - command execution logs -->
    <logger name="io.camunda.connector.sandbox.execution" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    
    <!-- Sandbox logger - sandbox lifecycle logs -->
    <logger name="io.camunda.connector.sandbox.sandbox" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </logger>
    
    <!-- Spring Framework loggers -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.web" level="WARN"/>
    
    <!-- Camunda SDK loggers -->
    <logger name="io.camunda" level="INFO"/>
    <logger name="io.camunda.connector" level="INFO"/>
    
    <!-- Reduce noise from common libraries -->
    <logger name="org.apache.http" level="WARN"/>
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="io.netty" level="WARN"/>
    
    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>
    
    <!-- Profile-specific configurations -->
    
    <!-- Development profile - more verbose logging -->
    <springProfile name="dev,local">
        <logger name="io.camunda.connector.sandbox" level="DEBUG"/>
        <logger name="org.springframework" level="INFO"/>
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
    
    <!-- Production profile - JSON logging for log aggregation -->
    <springProfile name="prod,production,kubernetes,k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
        <logger name="io.camunda.connector.sandbox" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>
        <logger name="io.camunda.connector.sandbox.audit" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="ASYNC_AUDIT"/>
        </logger>
        <logger name="io.camunda.connector.sandbox.security" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="ASYNC_SECURITY"/>
        </logger>
    </springProfile>
    
    <!-- Test profile - minimal logging -->
    <springProfile name="test">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="io.camunda.connector.sandbox" level="INFO"/>
    </springProfile>
    
</configuration>
