show_version() {
    echo "safe-python3 version $VERSION"
    echo "Security wrapper for Python 3 in sandboxed environments"
}

# Find available python3 binary
find_python() {
    for p in /bin/python3.10 /bin/python3.11 /bin/python3.12 /bin/python3 \
             /usr/bin/python3.10 /usr/bin/python3.11 /usr/bin/python3.12 /usr/bin/python3; do
        if [[ -x "$p" ]]; then
            echo "$p"
            return 0
        fi
    done
    return 1
}

# Get human-readable category for a blocked pattern
get_blocked_category() {
    local pattern="$1"
    
    case "$pattern" in
        *os*|*subprocess*|*pty*|*commands*|*popen*)
            echo "Process Execution" ;;
        *socket*|*urllib*|*http*|*ssl*|*ftp*|*smtp*|*imap*|*pop*|*telnet*|*xmlrpc*|*requests*|*aiohttp*|*httpx*|*asyncio*)
            echo "Network Access" ;;
        *ctypes*|*multiprocessing*|*threading*|*_thread*|*signal*|*resource*|*fcntl*|*mmap*)
            echo "System Access" ;;
        *shutil*|*tempfile*|*glob*)
            echo "File Operations" ;;
        *__import__*|*exec*|*eval*|*compile*|*importlib*|*builtins*)
            echo "Code Execution" ;;
        *pickle*|*cPickle*|*marshal*|*shelve*)
            echo "Serialization" ;;
        *inspect*|*dis*|*code*)
            echo "Code Introspection" ;;
        *sys\.*)
            echo "Dangerous sys Operations" ;;
        *pip*|*easy_install*)
            echo "Package Installation" ;;
        *)
            echo "Security" ;;
    esac
}

# Get suggestion for blocked operation
get_suggestion() {
    local category="$1"
    
    case "$category" in
        "Process Execution")
            echo "TIP: Use dedicated CLI tools (curl, jq, etc.) instead of Python subprocess." ;;
        "Network Access")
            echo "TIP: Use the 'curl' or 'http' tool for HTTP requests instead of Python networking." ;;
        "File Operations")
            echo "TIP: File operations are restricted. Process data in memory using allowed modules." ;;
        "Code Execution")
            echo "TIP: Dynamic code execution is blocked. Write your logic directly in the -c argument." ;;
        "Serialization")
            echo "TIP: Use 'json' module for serialization instead of pickle/marshal." ;;
        *)
            echo "TIP: Run 'safe-python3 --help' to see allowed modules and examples." ;;
    esac
}

# Check code for blocked patterns
check_code() {
    local code="$1"
    
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        if echo "$code" | grep -qEi "$pattern"; then
            local category=$(get_blocked_category "$pattern")
            local suggestion=$(get_suggestion "$category")
            
            echo "" >&2
            echo "========================================" >&2
            echo "SECURITY VIOLATION: $category" >&2
            echo "========================================" >&2
            echo "" >&2
            echo "Blocked pattern: $pattern" >&2
            echo "" >&2
            echo "$suggestion" >&2
            echo "" >&2
            echo "Run 'safe-python3 --help' for allowed modules." >&2
            echo "Run 'safe-python3 --capabilities' for JSON output." >&2
            echo "" >&2
            return 1
        fi
    done
    
    return 0
}

# =============================================================================
# MAIN
# =============================================================================

PYTHON_BIN=$(find_python)
if [[ -z "$PYTHON_BIN" ]]; then
    echo "ERROR: No Python 3 interpreter found." >&2
    exit 1
fi

# Parse arguments
CODE=""
MODE=""

# Handle no arguments
if [[ $# -eq 0 ]]; then
    echo "ERROR: No arguments provided." >&2
    echo "" >&2
    echo "Usage: safe-python3 -c 'your_code_here'" >&2
    echo "       safe-python3 --help" >&2
    echo "" >&2
    echo "Example: safe-python3 -c 'import json; print(json.dumps({\"x\": 1}))'" >&2
    exit 1
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        --capabilities)
            show_capabilities
            exit 0
            ;;
        --version)
            show_version
            exit 0
            ;;
        -c)
            MODE="inline"
            if [[ -z "$2" ]]; then
                echo "ERROR: -c requires a code argument." >&2
                echo "Usage: safe-python3 -c 'your_code_here'" >&2
                exit 1
            fi
            CODE="$2"
            shift 2
            ;;
        -m)
            # Module mode - only allow safe modules
            MODULE="$2"
            ALLOWED_PATTERN="^($(IFS='|'; echo "${ALLOWED_MODULES[*]}"))$"
            if [[ "$MODULE" =~ $ALLOWED_PATTERN ]]; then
                exec "$PYTHON_BIN" "$@"
            else
                echo "" >&2
                echo "ERROR: Module '$MODULE' is not in the allowed list." >&2
                echo "" >&2
                echo "Allowed modules:" >&2
                printf '  %s\n' "${ALLOWED_MODULES[@]}" >&2
                echo "" >&2
                echo "Run 'safe-python3 --help' for more information." >&2
                exit 1
            fi
            ;;
        -u|-E|-s|-S)
            # Safe flags, ignore
            shift
            ;;
        -i|--interactive)
            echo "" >&2
            echo "ERROR: Interactive mode is not allowed in sandbox." >&2
            echo "" >&2
            echo "Use inline code instead: safe-python3 -c 'your_code_here'" >&2
            exit 1
            ;;
        -*)
            echo "" >&2
            echo "ERROR: Unknown or blocked flag: $1" >&2
            echo "" >&2
            echo "Allowed flags: -c (inline code)" >&2
            echo "Run 'safe-python3 --help' for usage information." >&2
            exit 1
            ;;
        *)
            # Check if this is a file path in the allowed workspace directory
            if [[ "$1" == /workspace/*.py ]]; then
                # Allow execution of Python files from the workspace directory
                SCRIPT_FILE="$1"
                MODE="file"
                shift
            else
                echo "" >&2
                echo "ERROR: File execution is only allowed for scripts in /workspace/." >&2
                echo "" >&2
                echo "Provided path: $1" >&2
                echo "" >&2
                echo "For inline code, use:" >&2
                echo "  safe-python3 -c 'your_code_here'" >&2
                exit 1
            fi
            ;;
    esac
done

# Handle file mode
if [[ "$MODE" == "file" ]]; then
    if [[ ! -f "$SCRIPT_FILE" ]]; then
        echo "" >&2
        echo "ERROR: Script file not found: $SCRIPT_FILE" >&2
        exit 1
    fi
    
    # Read and validate the script file content
    SCRIPT_CONTENT=$(cat "$SCRIPT_FILE")
    if ! check_code "$SCRIPT_CONTENT"; then
        exit 1
    fi
    
    # Execute the script file
    exec "$PYTHON_BIN" -I -u "$SCRIPT_FILE"
fi

# If no code provided
if [[ -z "$CODE" && "$MODE" != "module" ]]; then
    echo "" >&2
    echo "ERROR: No code provided." >&2
    echo "" >&2
    echo "Usage: safe-python3 -c 'your_code_here'" >&2
    echo "" >&2
    echo "Example: safe-python3 -c 'print(2 + 2)'" >&2
    exit 1
fi

# Check the code for blocked patterns
if ! check_code "$CODE"; then
    exit 1
fi

# Execute the code in a restricted environment
# - Isolated mode (-I): ignore PYTHON* env vars and user site-packages
# - Unbuffered output (-u)
exec "$PYTHON_BIN" -I -u -c "$CODE"
