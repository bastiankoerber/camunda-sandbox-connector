#!/bin/bash
# safe-python3 - A security wrapper for Python 3 in sandboxed environments
# This script blocks dangerous module imports before executing Python code
#
# Usage: safe-python3 -c 'your_code_here'
#        safe-python3 --help
#        safe-python3 --capabilities (JSON output for API integration)

set -e

VERSION="1.0.0"

# =============================================================================
# ALLOWED MODULES - Safe for sandbox execution
# =============================================================================
ALLOWED_MODULES=(
    # Data formats
    "json"          # JSON encoding/decoding
    "csv"           # CSV file reading/writing
    "html"          # HTML escaping
    "xml.etree.ElementTree"  # XML parsing
    
    # Math & numbers
    "math"          # Mathematical functions
    "decimal"       # Decimal fixed-point arithmetic
    "fractions"     # Rational numbers
    "statistics"    # Statistical functions
    "random"        # Random number generation
    
    # Text processing
    "re"            # Regular expressions
    "string"        # String constants and utilities
    "textwrap"      # Text wrapping and filling
    "difflib"       # Sequence comparison
    
    # Data structures
    "collections"   # Specialized container datatypes
    "itertools"     # Iterator building blocks
    "functools"     # Higher-order functions
    "operator"      # Standard operators as functions
    "copy"          # Shallow and deep copy
    
    # Type system
    "typing"        # Type hints
    "enum"          # Enumeration support
    "dataclasses"   # Data classes
    
    # Encoding & hashing
    "base64"        # Base64 encoding/decoding
    "hashlib"       # Secure hash algorithms (SHA, MD5)
    "hmac"          # Keyed-hashing for authentication
    
    # Utilities
    "datetime"      # Date and time handling
    "uuid"          # UUID generation
    "pprint"        # Pretty-printing
    "argparse"      # Command-line argument parsing
    "configparser"  # Configuration file parsing
)

# =============================================================================
# BLOCKED CATEGORIES - Not allowed in sandbox
# =============================================================================
declare -A BLOCKED_CATEGORIES=(
    ["Process Execution"]="os, subprocess, pty, commands, popen2"
    ["Network Access"]="socket, urllib, requests, http.client, http.server, ssl, ftplib, smtplib, imaplib, poplib, telnetlib, xmlrpc, aiohttp, httpx, asyncio"
    ["System Access"]="ctypes, multiprocessing, threading, _thread, signal, resource, fcntl, mmap"
    ["File Operations"]="shutil, tempfile, glob"
    ["Code Execution"]="exec(), eval(), compile(), __import__(), importlib, builtins, __builtins__"
    ["Serialization"]="pickle, cPickle, marshal, shelve"
    ["Code Introspection"]="inspect, dis, code, codeop"
    ["Dangerous sys"]="sys.exit, sys.modules, sys.path, sys.executable"
)

# Blocked patterns (regex)
BLOCKED_PATTERNS=(
    # Process execution
    'import\s+os' 'from\s+os\s+import'
    'import\s+subprocess' 'from\s+subprocess\s+import'
    'import\s+pty' 'from\s+pty\s+import'
    'import\s+commands' 'from\s+commands\s+import'
    'import\s+popen2' 'from\s+popen2\s+import'
    
    # Network access
    'import\s+socket' 'from\s+socket\s+import'
    'import\s+urllib' 'from\s+urllib\s+import'
    'import\s+http\.client' 'from\s+http\.client\s+import'
    'import\s+http\.server' 'from\s+http\.server\s+import'
    'import\s+ssl' 'from\s+ssl\s+import'
    'import\s+ftplib' 'from\s+ftplib\s+import'
    'import\s+smtplib' 'from\s+smtplib\s+import'
    'import\s+imaplib' 'from\s+imaplib\s+import'
    'import\s+poplib' 'from\s+poplib\s+import'
    'import\s+telnetlib' 'from\s+telnetlib\s+import'
    'import\s+xmlrpc' 'from\s+xmlrpc\s+import'
    'import\s+requests' 'from\s+requests\s+import'
    'import\s+aiohttp' 'from\s+aiohttp\s+import'
    'import\s+httpx' 'from\s+httpx\s+import'
    'import\s+asyncio' 'from\s+asyncio\s+import'
    
    # System/low-level access
    'import\s+ctypes' 'from\s+ctypes\s+import'
    'import\s+multiprocessing' 'from\s+multiprocessing\s+import'
    'import\s+threading' 'from\s+threading\s+import'
    'import\s+_thread' 'from\s+_thread\s+import'
    'import\s+signal' 'from\s+signal\s+import'
    'import\s+resource' 'from\s+resource\s+import'
    'import\s+fcntl' 'from\s+fcntl\s+import'
    'import\s+mmap' 'from\s+mmap\s+import'
    
    # Dangerous file operations
    'import\s+shutil' 'from\s+shutil\s+import'
    'import\s+tempfile' 'from\s+tempfile\s+import'
    'import\s+glob' 'from\s+glob\s+import'
    
    # Code execution/dynamic imports
    '__import__\s*\(' 'exec\s*\(' 'eval\s*\(' 'compile\s*\('
    'importlib\.import_module'
    'import\s+importlib' 'from\s+importlib\s+import'
    'import\s+builtins' 'from\s+builtins\s+import'
    '__builtins__'
    
    # Serialization (arbitrary code execution)
    'import\s+pickle' 'from\s+pickle\s+import'
    'import\s+cPickle' 'from\s+cPickle\s+import'
    'import\s+marshal' 'from\s+marshal\s+import'
    'import\s+shelve' 'from\s+shelve\s+import'
    
    # Code introspection/manipulation
    'import\s+inspect' 'from\s+inspect\s+import'
    'import\s+dis' 'from\s+dis\s+import'
    'import\s+code' 'from\s+code\s+import'
    'import\s+codeop' 'from\s+codeop\s+import'
    
    # Dangerous sys operations
    'sys\.exit' 'sys\.modules' 'sys\.path' 'sys\.executable'
    
    # Package installation
    'pip\s+install' 'pip3\s+install' 'easy_install'
)

# =============================================================================
# HELPER FUNCTIONS
# =============================================================================

show_help() {
    cat << 'EOF'
SAFE-PYTHON3 - Secure Python 3 Interpreter for Sandbox Execution
=================================================================

USAGE:
    safe-python3 -c 'your_python_code'
    safe-python3 /workspace/script.py
    safe-python3 --help
    safe-python3 --capabilities

DESCRIPTION:
    This is a security wrapper around Python 3 that blocks dangerous operations
    to ensure safe execution in sandboxed environments. Supports inline code 
    execution (-c flag) and file execution from the /workspace/ directory.

EXAMPLES:
    # JSON processing (inline)
    safe-python3 -c 'import json; print(json.dumps({"key": "value"}))'
    
    # Math calculations (inline)
    safe-python3 -c 'import math; print(math.sqrt(2))'
    
    # Execute script from workspace
    safe-python3 /workspace/script.py
    
    # Multi-line data transformation (inline)
    safe-python3 -c '
    import json, base64
    data = {"msg": base64.b64encode(b"hello").decode()}
    print(json.dumps(data))
    '
    
    # Text processing with regex
    safe-python3 -c '
    import re
    text = "Hello World 123"
    numbers = re.findall(r"\d+", text)
    print(numbers)
    '

ALLOWED MODULES:
    Data Formats:    json, csv, html, xml.etree.ElementTree
    Math & Numbers:  math, decimal, fractions, statistics, random
    Text Processing: re, string, textwrap, difflib
    Data Structures: collections, itertools, functools, operator, copy
    Type System:     typing, enum, dataclasses
    Encoding:        base64, hashlib, hmac
    Utilities:       datetime, uuid, pprint, argparse, configparser

BLOCKED OPERATIONS (for security):
    Process Execution:   os, subprocess, pty, commands
    Network Access:      socket, urllib, requests, http.*, ssl, asyncio
    System Access:       ctypes, multiprocessing, threading, signal
    File Operations:     shutil, tempfile, glob
    Code Execution:      exec(), eval(), compile(), __import__()
    Serialization:       pickle, marshal, shelve
    Code Introspection:  inspect, dis, code

RESTRICTIONS:
    - Inline code (-c 'code') is allowed
    - File execution only from /workspace/ directory
    - No interactive mode (-i is blocked)
    - No package installation (pip is blocked)
    - Read-only filesystem access (except /workspace)

RESOURCE LIMITS:
    - Memory: 256 MB
    - CPU Time: 60 seconds
    - Output Size: Limited by sandbox

EXIT CODES:
    0 - Success
    1 - Security violation or error

OPTIONS:
    -c CODE              Execute inline Python code
    /workspace/*.py      Execute a Python script from the workspace
    -h, --help           Show this help message
    --capabilities       Output capabilities as JSON (for API integration)
    --version            Show version information

For network requests, use the 'curl' tool instead.
For file operations, use allowed sandbox tools.
EOF
}

